# Copy to .env. Nested config uses the __ delimiter (see src/events_curator/config.py).

# --- LLM (dedup tiebreak, rank reranker, profile summaries) ---
LLM__PROVIDER=openai
LLM__MODEL=gpt-4o-mini
LLM__API_KEY=

# --- Embeddings (dedup similarity, taste vectors) ---
EMBEDDING__KIND=bge_small
EMBEDDING__MODEL=BAAI/bge-small-en-v1.5

# --- Search ---
SEARCH__ENGINE=frontier_native

# --- Dedup thresholds ---
DEDUP__AUTO_MERGE_THRESHOLD=0.88
DEDUP__TIEBREAK_LOW_THRESHOLD=0.75
DEDUP__BLOCK_WINDOW_DAYS=1

# --- Storage ---
STORAGE__DB_PATH=./events.db

# --- Auth (DB is multi-user; pick how callers are identified) ---
AUTH__SCHEME=local
AUTH__API_TOKEN=

# --- Server / scheduler ---
SERVER__SCHEDULER_TICK_SECONDS=300
