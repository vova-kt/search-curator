{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./types",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.js", "src/**/*.d.ts", "app/**/*.js", "examples/**/*.js", "eval/**/*.js", "test/**/*.js"],
  "exclude": ["node_modules", "types", "app", "test", "eval/**/report.js", "eval/**/grid.js"]
}
